{
  "name": "toast-builder-vue3",
  "private": false,
  "version": "1.0.15",
  "type": "module",
  "description": "Modern, lightweight, and fully customizable toast notification system for Vue 3 with TypeScript. Beautiful alerts, snackbars, and notifications with animations, icons, and progress bars.",
  "author": "Canberk Beren",
  "license": "GPL-3.0",
  "keywords": [
    "vue",
    "vue3",
    "vuejs",
    "toast",
    "notification",
    "toaster",
    "notifications",
    "message",
    "alert",
    "snackbar",
    "popup",
    "vue-toast",
    "vue-notification",
    "toast-notification",
    "vue3-toast",
    "typescript",
    "composition-api",
    "notification-system",
    "toast-message",
    "vue-component",
    "ui-component",
    "vite",
    "builder",
    "customizable",
    "progress-bar",
    "animation",
    "icons",
    "position",
    "success",
    "error",
    "warning",
    "info"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/highpriv/toast-builder"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "preview": "vite preview",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "nanoid": "^5.0.7",
    "toast-builder-vue3": "^1.0.9",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.59.0",
    "rollup-plugin-vue": "^6.0.0",
    "sass": "^1.77.0",
    "ts-jest": "^29.2.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts"
}
